{
  "name": "@sayoriqwq/prelude",
  "type": "module",
  "version": "0.3.0",
  "description": "Effect v4 multi-Harness convergence host for pnpm targets",
  "author": "sayoriqwq",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/yume-infra/prelude.git"
  },
  "keywords": [
    "cli",
    "convergence",
    "effect",
    "harness",
    "pnpm"
  ],
  "main": "dist/index.js",
  "bin": {
    "prelude": "dist/index.js"
  },
  "files": [
    "dist",
    "skills"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsdown --config tsdown.config.ts",
    "dev": "tsdown --config tsdown.config.ts --watch",
    "typecheck": "node ../../scripts/run-tsgo.mjs --noEmit --project tsconfig.json",
    "typecheck:tsc": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "eslint .",
    "verify": "pnpm build && pnpm typecheck && pnpm test && pnpm lint --max-warnings 0",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "@effect/platform-node": "catalog:",
    "@sayoriqwq/prelude-contract": "workspace:^",
    "effect": "catalog:",
    "import-meta-resolve": "catalog:",
    "jsonc-parser": "catalog:",
    "semver": "catalog:",
    "yaml": "catalog:"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:",
    "@effect/language-service": "catalog:",
    "@effect/tsgo": "catalog:",
    "@effect/vitest": "catalog:",
    "@types/node": "catalog:",
    "@types/semver": "catalog:",
    "@typescript/native": "catalog:",
    "eslint": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  }
}
