{
  "name": "@sayoriqwq/prelude",
  "type": "module",
  "version": "0.3.0",
  "description": "Effect v4 multi-Harness convergence host for pnpm targets",
  "author": "sayoriqwq",
  "license": "ISC",
  "keywords": [
    "cli",
    "convergence",
    "effect",
    "harness",
    "pnpm"
  ],
  "main": "dist/index.js",
  "bin": {
    "prelude": "dist/index.js"
  },
  "files": [
    "dist",
    "skills"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsdown --config tsdown.config.ts",
    "dev": "tsdown --config tsdown.config.ts --watch",
    "typecheck": "tsgo --noEmit",
    "typecheck:tsc": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "smoke:installed": "pnpm build && node --experimental-strip-types tests/installed-tracer.ts",
    "smoke:packed-effect": "node --experimental-strip-types tests/packed-effect-gate.ts",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "@effect/platform-node": "4.0.0-beta.97",
    "@sayoriqwq/prelude-contract": "workspace:^",
    "effect": "4.0.0-beta.97",
    "import-meta-resolve": "catalog:",
    "jsonc-parser": "catalog:",
    "semver": "catalog:",
    "yaml": "catalog:"
  },
  "devDependencies": {
    "@effect/language-service": "0.86.6",
    "@effect/tsgo": "0.19.0",
    "@effect/vitest": "4.0.0-beta.97",
    "@types/node": "catalog:",
    "@types/semver": "catalog:",
    "@typescript/native": "catalog:",
    "execa": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "^4.1.8"
  },
  "publishConfig": {
    "access": "public"
  }
}
