{
  "name": "@sayoriqwq/prelude",
  "type": "module",
  "version": "0.2.3",
  "description": "A focused local project scaffolding CLI for React, Vue, Node, CLI tools, libraries, and pnpm workspaces",
  "author": "sayoriqwq",
  "license": "ISC",
  "keywords": [
    "create",
    "cli",
    "scaffold",
    "generator",
    "pnpm"
  ],
  "main": "dist/index.js",
  "bin": {
    "prelude": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsdown --config tsdown.config.ts",
    "dev": "tsdown --config tsdown.config.ts --watch",
    "typecheck": "tsgo --noEmit",
    "typecheck:tsc": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "prototype:create-workbench": "tsx src/core/create-workbench-prototype/index.ts",
    "smoke:generated": "pnpm build && tsx tests/generated-projects.smoke.ts",
    "smoke:examples": "pnpm build && tsx tests/generated-projects.smoke.ts",
    "prepare": "effect-tsgo patch",
    "link:global": "pnpm link --global",
    "unlink:global": "pnpm unlink --global"
  },
  "dependencies": {
    "@clack/prompts": "catalog:",
    "@effect/platform-node": "4.0.0-beta.92",
    "effect": "4.0.0-beta.92",
    "strip-json-comments": "catalog:"
  },
  "devDependencies": {
    "@effect/language-service": "0.86.2",
    "@effect/tsgo": "0.15.0",
    "@effect/vitest": "4.0.0-beta.92",
    "@types/node": "catalog:",
    "@typescript/native-preview": "7.0.0-dev.20260630.1",
    "execa": "catalog:",
    "tsdown": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "^4.1.8"
  }
}
