{
  "name": "create-yume",
  "type": "module",
  "version": "0.0.1",
  "description": "A CLI tool for scaffolding opinionated projects",
  "author": "sayoriqwq",
  "license": "ISC",
  "keywords": [
    "cli",
    "tool"
  ],
  "main": "dist/index.js",
  "bin": {
    "create-yume": "dist/index.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsdown --config tsdown.config.ts",
    "dev": "tsdown --config tsdown.config.ts --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "smoke:generated": "pnpm build && tsx tests/generated-projects.smoke.ts",
    "smoke:dry-run": "pnpm build && tsx tests/dry-run-cli.smoke.ts",
    "smoke:lint-strategy": "pnpm build && tsx tests/generated-lint-strategy.smoke.ts",
    "smoke:examples": "pnpm build && tsx tests/linked-examples.smoke.ts",
    "prepare": "effect-language-service patch",
    "link:global": "pnpm link --global",
    "unlink:global": "pnpm unlink --global"
  },
  "dependencies": {
    "@clack/prompts": "catalog:",
    "@effect/cluster": "catalog:",
    "@effect/experimental": "catalog:",
    "@effect/opentelemetry": "catalog:",
    "@effect/platform": "catalog:",
    "@effect/platform-node": "catalog:",
    "@effect/rpc": "catalog:",
    "@effect/sql": "catalog:",
    "@effect/workflow": "catalog:",
    "@opentelemetry/exporter-trace-otlp-http": "catalog:",
    "@opentelemetry/sdk-trace-base": "catalog:",
    "@opentelemetry/sdk-trace-node": "catalog:",
    "effect": "catalog:",
    "execa": "catalog:",
    "handlebars": "catalog:",
    "immer": "catalog:",
    "lodash-es": "catalog:",
    "mri": "catalog:"
  },
  "devDependencies": {
    "@effect/language-service": "catalog:",
    "@types/lodash-es": "catalog:",
    "@types/node": "catalog:",
    "tsdown": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
