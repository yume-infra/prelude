{
  "name": "@sayoriqwq/prelude",
  "type": "module",
  "version": "0.2.3",
  "description": "A focused local project scaffolding CLI for React, Vue, Node, CLI tools, libraries, and pnpm workspaces",
  "author": "sayoriqwq",
  "license": "ISC",
  "keywords": [
    "create",
    "cli",
    "scaffold",
    "generator",
    "pnpm"
  ],
  "main": "dist/index.js",
  "bin": {
    "prelude": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsdown --config tsdown.config.ts",
    "dev": "tsdown --config tsdown.config.ts --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "smoke:generated": "pnpm build && tsx tests/generated-projects.smoke.ts",
    "smoke:examples": "pnpm build && tsx tests/generated-projects.smoke.ts",
    "prepare": "effect-language-service patch --dir ../../node_modules/typescript",
    "link:global": "pnpm link --global",
    "unlink:global": "pnpm unlink --global"
  },
  "dependencies": {
    "@clack/prompts": "catalog:",
    "@effect/experimental": "catalog:",
    "@effect/opentelemetry": "catalog:",
    "@effect/platform": "catalog:",
    "@effect/platform-node": "catalog:",
    "@opentelemetry/exporter-trace-otlp-http": "catalog:",
    "@opentelemetry/sdk-trace-base": "catalog:",
    "@opentelemetry/sdk-trace-node": "catalog:",
    "effect": "catalog:",
    "mri": "catalog:"
  },
  "devDependencies": {
    "@effect/language-service": "catalog:",
    "@types/node": "catalog:",
    "execa": "catalog:",
    "tsdown": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
