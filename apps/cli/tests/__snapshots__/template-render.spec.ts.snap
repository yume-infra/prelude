exports[`template render snapshots > renders vue counter store 1`] = `
"import { defineStore } from 'pinia'
import { computed, ref } from 'vue'

export const useCounterStore = defineStore('counter', () => {
  const count = ref(0)

  const doubleCount = computed(() => count.value * 2)

  function increment() {
    count.value++
  }

  function decrement() {
    count.value--
  }

  return {
    count,
    doubleCount,
    increment,
    decrement,
  }
})
"
`;

exports[`template render snapshots > renders vue counter with state management 1`] = `
"<script setup lang="ts">
import { storeToRefs } from 'pinia'
import { useCounterStore } from '../stores/counter'

const store = useCounterStore()
const { count } = storeToRefs(store)
const inc = store.increment
const dec = store.decrement
</script>

<template>
  <div class="counter">
    <div class="counter-row">
      <button
        type="button"
        class="btn btn-sm"
        aria-label="decrement"
        @click="dec"
      >
        -
      </button>
      <span class="count" aria-live="polite">
        {{ count }}
      </span>
      <button
        type="button"
        class="btn btn-sm"
        aria-label="increment"
        @click="inc"
      >
        +
      </button>
    </div>
  </div>
</template>

<style scoped lang="less">
.counter { margin: 8px auto; max-width: 320px; }
.counter-row { display: flex; align-items: center; gap: 8px; justify-content: center; }
.count { min-width: 40px; text-align: center; padding: 4px 8px; border: 1px solid #ddd; border-radius: 6px; }
.btn { padding: 6px 10px; border: 1px solid #ddd; background: #f7f7f7; border-radius: 6px; cursor: pointer; }
.btn.btn-sm { font-size: 14px; }
</style>
"
`;

