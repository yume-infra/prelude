exports[`template render snapshots > renders node runtime entry 1`] = `
"import { realpathSync } from 'node:fs'
import { fileURLToPath } from 'node:url'

export function renderMessage(name = 'world'): string {
  return \`Hello, \${name}!\`
}

export function main(args: readonly string[] = process.argv.slice(2)): void {
  const [name] = args
  console.log(renderMessage(name))
}

function isDirectRun(metaUrl: string, argvEntry: string | undefined): boolean {
  if (!argvEntry) {
    return false
  }

  try {
    return realpathSync(fileURLToPath(metaUrl)) === realpathSync(argvEntry)
  }
  catch {
    return false
  }
}

if (isDirectRun(import.meta.url, process.argv[1])) {
  main()
}
"
`;

