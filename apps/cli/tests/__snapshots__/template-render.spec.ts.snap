exports[`template render snapshots > renders react counter component with jotai 1`] = `
"import { useAtom } from 'jotai'
import { countAtom } from '../stores/counter'

export default function Counter() {
  const [count, setCount] = useAtom(countAtom)
  const inc = () => setCount(c => c + 1)
  const dec = () => setCount(c => c - 1)
  return (
    <div className="counter">
      <div className="counter-row">
        <button type="button" className="btn btn-sm" onClick={dec} aria-label="decrement">-</button>
        <span className="count" aria-live="polite">{count}</span>
        <button type="button" className="btn btn-sm" onClick={inc} aria-label="increment">+</button>
      </div>
    </div>
  )
}
"
`;

