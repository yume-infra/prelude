exports[`template render snapshots > renders react shared style without router-specific config branching 1`] = `
"
@import "tailwindcss";

/* ==== Base & Counter ==== */
.container { max-width: 960px; margin: 0 auto; padding: 0 16px; }
.content { padding: 8px 0; }
h1 { font-size: 22px; margin: 16px 0 8px; }
h2 { font-size: 18px; margin: 14px 0 8px; }
p { margin: 8px 0; }
.block { margin: 12px 0; }
.home { padding: 16px 0; }
.counter { margin: 12px auto; max-width: 320px; }
.counter-row { display: flex; align-items: center; gap: 8px; justify-content: center; }
.count { min-width: 42px; text-align: center; padding: 4px 8px; border: 1px solid #ddd; border-radius: 6px; background: #fff; }
.btn { padding: 6px 10px; border: 1px solid #d0d0d0; background: #fafafa; border-radius: 6px; cursor: pointer; transition: background .15s; }
.btn:hover { background: #f0f0f0; }
.btn.btn-sm { font-size: 14px; }

/* ==== Router (adds navigation & about page) ==== */
.nav { display: flex; gap: 8px; padding: 12px 0; flex-wrap: wrap; }
.nav-link { text-decoration: none; color: inherit; padding: 4px 8px; border-radius: 4px; }
.nav-link:hover { background: #f3f3f3; }
.router-link-active { font-weight: 600; text-decoration: underline; }
.about { padding: 16px 0; }

"
`;

