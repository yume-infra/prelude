  <div id="app">
    <main class="container">
      <nav class="nav">
        <RouterLink to="/" class="nav-link">Home</RouterLink>
        <RouterLink to="/about" class="nav-link">About</RouterLink>
      </nav>

      <section class="content">
        <RouterView />
      </section>
    </main>
  </div>
</template>

<style scoped lang="less">.container { max-width: 960px; margin: 0 auto; padding: 0 16px; }
.nav { display: flex; gap: 8px; padding: 12px 0; flex-wrap: wrap; }
.nav-link { text-decoration: none; color: inherit; padding: 4px 8px; }
.router-link-active { font-weight: 600; text-decoration: underline; }
.content { padding: 8px 0; }
</style>
"
`;

