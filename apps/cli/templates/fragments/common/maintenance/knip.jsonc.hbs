{{#if (eq @config.type "cli")}}
{
  "$schema": "https://unpkg.com/knip@6/schema-jsonc.json",
  "ignoreBinaries": [
    "dist/index.js"
  ]
}
{{else if (eq @config.type "workspace-root")}}
{{#if @config.packages}}
{
  "$schema": "https://unpkg.com/knip@6/schema-jsonc.json",
  "workspaces": {
{{#each @config.packages}}
{{#if (eq kind "library-package")}}
    "libs/{{id}}": {
{{else}}
    "apps/{{id}}": {
{{/if}}
{{#if (eq kind "cli-tool")}}
      "ignoreBinaries": [
        "dist/index.js"
      ]{{#if (eq frontend.cssFramework "tailwind")}},{{/if}}
{{/if}}
{{#if (eq frontend.cssFramework "tailwind")}}
      "ignoreDependencies": [
        "tailwindcss"
      ]
{{/if}}
    }{{#unless @last}},{{/unless}}
{{/each}}
  }
}
{{else}}
{
  "$schema": "https://unpkg.com/knip@6/schema-jsonc.json"
}
{{/if}}
{{else}}
{
  "$schema": "https://unpkg.com/knip@6/schema-jsonc.json"{{#if (eq @config.cssFramework "tailwind")}},
  "ignoreDependencies": [
    "tailwindcss"
  ]{{/if}}
}
{{/if}}
