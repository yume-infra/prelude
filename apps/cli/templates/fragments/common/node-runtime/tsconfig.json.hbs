{{#withHash hasNodeTypes=(or (eq @config.type "node") (eq @config.type "cli") (eq @config.runtime "node"))}}
{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "moduleDetection": "force",
    "strict": true,
    "declaration": true,
    "outDir": "dist",
    "rootDir": "src",
{{#if hasNodeTypes}}
    "types": ["node"],
{{/if}}
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true
  },
  "include": ["src"]
}
{{/withHash}}
