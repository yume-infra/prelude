{
  "name": "prelude-workspace",
  "private": true,
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "clean": "turbo run clean && rm -rf node_modules",
    "verify": "pnpm --filter @sayoriqwq/prelude build && pnpm typecheck && pnpm --filter @sayoriqwq/prelude test && pnpm lint && pnpm knip && pnpm effect:verify",
    "verify:code": "pnpm --filter @sayoriqwq/prelude build && pnpm typecheck && pnpm --filter @sayoriqwq/prelude test && pnpm lint && pnpm knip",
    "prototype:create-workbench": "pnpm --filter @sayoriqwq/prelude prototype:create-workbench",
    "smoke:examples": "pnpm --filter @sayoriqwq/prelude smoke:examples",
    "deps:check": "taze -r",
    "deps:check:all": "taze -r --all",
    "deps:fresh": "taze minor -r -w -i --maturity-period 7",
    "outdated": "pnpm outdated -r",
    "deps": "pnpm update -r",
    "deps:latest": "pnpm update -r --latest",
    "build:cli": "pnpm --filter @sayoriqwq/prelude build",
    "link": "pnpm --filter @sayoriqwq/prelude link --global",
    "unlink": "pnpm --filter @sayoriqwq/prelude unlink --global",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm verify && pnpm smoke:examples && changeset publish",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "prepare": "node -e \"if (require('node:fs').existsSync('.git')) require('node:child_process').execFileSync('husky', { stdio: 'inherit', shell: true })\" && effect-tsgo patch",
    "knip": "knip",
    "effect:status": "node \"/Users/sayori/Desktop/yume-infra/effect-harness/dist/bin/effect-harness.js\" status",
    "effect:verify": "node \"/Users/sayori/Desktop/yume-infra/effect-harness/dist/bin/effect-harness.js\" verify --target .",
    "typecheck": "tsgo --noEmit --project apps/cli/tsconfig.json",
    "typecheck:tsc": "pnpm --filter @sayoriqwq/prelude typecheck:tsc"
  },
  "dependencies": {
    "@effect/platform-node": "4.0.0-beta.90",
    "effect": "4.0.0-beta.90"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:",
    "@changesets/cli": "catalog:",
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@effect/language-service": "0.86.2",
    "@effect/tsgo": "catalog:",
    "@effect/vitest": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "eslint": "catalog:",
    "husky": "catalog:",
    "knip": "catalog:",
    "lint-staged": "catalog:",
    "taze": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  }
}
