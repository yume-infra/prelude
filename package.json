{
  "name": "prelude-workspace",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "clean": "turbo run clean && rm -rf node_modules",
    "verify": "pnpm verify:code",
    "verify:code": "pnpm build && pnpm typecheck && pnpm typecheck:smoke && pnpm -r --if-present test && pnpm lint --max-warnings 0 && pnpm knip",
    "smoke:installed": "pnpm --filter @sayoriqwq/prelude-contract build && pnpm --filter @sayoriqwq/prelude build && node --experimental-strip-types smoke/installed-tracer.ts",
    "smoke:packed-effect": "node --experimental-strip-types smoke/packed-effect-gate.ts",
    "deps:check": "taze -r",
    "deps:check:all": "taze -r --all",
    "deps:fresh": "taze minor -r -w -i --maturity-period 7",
    "outdated": "pnpm outdated -r",
    "deps": "pnpm update -r",
    "deps:latest": "pnpm update -r --latest",
    "build:cli": "pnpm --filter @sayoriqwq/prelude build",
    "link": "pnpm --filter @sayoriqwq/prelude link --global",
    "unlink": "pnpm --filter @sayoriqwq/prelude unlink --global",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm verify && pnpm smoke:installed && changeset publish",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "prepare": "effect-tsgo patch",
    "knip": "knip --exclude duplicates --no-config-hints",
    "typecheck": "pnpm -r --if-present typecheck",
    "typecheck:tsc": "pnpm -r --if-present typecheck:tsc",
    "typecheck:smoke": "tsc -p tsconfig.smoke.json --noEmit"
  },
  "dependencies": {
    "@effect/platform-node": "catalog:",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:",
    "@changesets/cli": "catalog:",
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@effect/language-service": "catalog:",
    "@effect/tsgo": "catalog:",
    "@effect/vitest": "catalog:",
    "@sayoriqwq/effect-harness": "file:tmp/gate-input/sayoriqwq-effect-harness-0.2.0.tgz",
    "@sayoriqwq/prelude": "workspace:^",
    "@types/node": "catalog:",
    "@typescript/native": "catalog:",
    "eslint": "catalog:",
    "execa": "catalog:",
    "husky": "catalog:",
    "knip": "catalog:",
    "lint-staged": "catalog:",
    "taze": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  }
}
