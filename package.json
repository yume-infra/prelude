{
  "name": "prelude-workspace",
  "private": true,
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "clean": "turbo run clean && rm -rf node_modules",
    "verify": "pnpm verify:code",
    "verify:code": "pnpm build && pnpm typecheck && pnpm -r --if-present test && pnpm lint --max-warnings 0 && pnpm knip",
    "prototype:create-workbench": "pnpm --filter @sayoriqwq/prelude prototype:create-workbench",
    "smoke:examples": "pnpm --filter @sayoriqwq/prelude smoke:examples",
    "deps:check": "taze -r",
    "deps:check:all": "taze -r --all",
    "deps:fresh": "taze minor -r -w -i --maturity-period 7",
    "outdated": "pnpm outdated -r",
    "deps": "pnpm update -r",
    "deps:latest": "pnpm update -r --latest",
    "build:cli": "pnpm --filter @sayoriqwq/prelude build",
    "link": "pnpm --filter @sayoriqwq/prelude link --global",
    "unlink": "pnpm --filter @sayoriqwq/prelude unlink --global",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm verify && pnpm smoke:examples && changeset publish",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "prepare": "effect-tsgo patch",
    "knip": "knip",
    "typecheck": "pnpm --filter @sayoriqwq/prelude typecheck",
    "typecheck:tsc": "pnpm --filter @sayoriqwq/prelude typecheck:tsc"
  },
  "dependencies": {
    "@effect/platform-node": "4.0.0-beta.92",
    "effect": "4.0.0-beta.92"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@changesets/cli": "catalog:",
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@effect/language-service": "0.86.2",
    "@effect/tsgo": "0.15.0",
    "@effect/vitest": "4.0.0-beta.92",
    "@types/node": "catalog:",
    "@typescript/native-preview": "7.0.0-dev.20260630.1",
    "eslint": "^10.3.0",
    "husky": "catalog:",
    "knip": "catalog:",
    "lint-staged": "catalog:",
    "taze": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  }
}
