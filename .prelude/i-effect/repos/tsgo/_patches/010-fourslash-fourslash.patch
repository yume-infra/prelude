+// GetQuickFixesForDiagnostics returns an inventory of quick fixes available for all
+// diagnostics in the given file. It sends a diagnostic request followed by per-diagnostic
+// code action requests, filtering to CodeActionKindQuickFix.
+func (f *FourslashTest) GetQuickFixesForDiagnostics(t *testing.T, fileURI lsproto.DocumentUri) []QuickFixInfo {
+	t.Helper()
+
+	// Get diagnostics
+	diagParams := &lsproto.DocumentDiagnosticParams{
+		TextDocument: lsproto.TextDocumentIdentifier{
+			Uri: fileURI,
+		},
+	}
+	diagResult := sendRequest(t, f, lsproto.TextDocumentDiagnosticInfo, diagParams)
+
+	var diagnostics []*lsproto.Diagnostic
+	if diagResult.FullDocumentDiagnosticReport != nil && diagResult.FullDocumentDiagnosticReport.Items != nil {
+		diagnostics = diagResult.FullDocumentDiagnosticReport.Items
+	}
+
+	if len(diagnostics) == 0 {
+		return nil
+	}
+
+	// Sort diagnostics deterministically by position then code
+	slices.SortStableFunc(diagnostics, func(a, b *lsproto.Diagnostic) int {
+		if c := int(a.Range.Start.Line) - int(b.Range.Start.Line); c != 0 {
+			return c
+		}
+		if c := int(a.Range.Start.Character) - int(b.Range.Start.Character); c != 0 {
+			return c
+		}
+		ac, bc := 0, 0
+		if a.Code != nil && a.Code.Integer != nil {
+			ac = int(*a.Code.Integer)
+		}
+		if b.Code != nil && b.Code.Integer != nil {
+			bc = int(*b.Code.Integer)
+		}
+		return ac - bc
+	})
+
+	var result []QuickFixInfo
+	for _, diag := range diagnostics {
+		// Request code actions for this specific diagnostic
+		params := &lsproto.CodeActionParams{
+			TextDocument: lsproto.TextDocumentIdentifier{
+				Uri: fileURI,
+			},
+			Range: diag.Range,
+			Context: &lsproto.CodeActionContext{
+				Diagnostics: []*lsproto.Diagnostic{diag},
+				Only:        &[]lsproto.CodeActionKind{lsproto.CodeActionKindQuickFix},
+			},
+		}
+		codeActions := sendRequest(t, f, lsproto.TextDocumentCodeActionInfo, params)
+
+		var titles []string
+		if codeActions.CommandOrCodeActionArray != nil {
+			for _, item := range *codeActions.CommandOrCodeActionArray {
+				if item.CodeAction != nil && item.CodeAction.Kind != nil && *item.CodeAction.Kind == lsproto.CodeActionKindQuickFix {
+					titles = append(titles, item.CodeAction.Title)
+				}
+			}
+		}
+
+		result = append(result, QuickFixInfo{
+			Diagnostic: diag,
+			FixTitles:  titles,
+		})
+	}
+
+	return result
+}
