+// ApplyQuickFix applies a specific quick fix for a diagnostic and returns the before/after
+// content for all affected files. After capturing the result, it undoes the changes to
+// restore the original state.
+func (f *FourslashTest) ApplyQuickFix(t *testing.T, fileURI lsproto.DocumentUri, diagnostic *lsproto.Diagnostic, fixIndex int) AppliedQuickFixResult {
+	t.Helper()
+
+	// Request code actions for this diagnostic
+	params := &lsproto.CodeActionParams{
+		TextDocument: lsproto.TextDocumentIdentifier{
+			Uri: fileURI,
+		},
+		Range: diagnostic.Range,
+		Context: &lsproto.CodeActionContext{
+			Diagnostics: []*lsproto.Diagnostic{diagnostic},
+			Only:        &[]lsproto.CodeActionKind{lsproto.CodeActionKindQuickFix},
+		},
+	}
+	codeActions := sendRequest(t, f, lsproto.TextDocumentCodeActionInfo, params)
+
+	// Filter to quick fixes only
+	var quickFixes []*lsproto.CodeAction
+	if codeActions.CommandOrCodeActionArray != nil {
+		for _, item := range *codeActions.CommandOrCodeActionArray {
+			if item.CodeAction != nil && item.CodeAction.Kind != nil && *item.CodeAction.Kind == lsproto.CodeActionKindQuickFix {
+				quickFixes = append(quickFixes, item.CodeAction)
+			}
+		}
+	}
+
+	if fixIndex >= len(quickFixes) {
+		t.Fatalf("Quick fix index %d out of range (have %d fixes)", fixIndex, len(quickFixes))
+	}
+
+	action := quickFixes[fixIndex]
+	result := AppliedQuickFixResult{
+		Diagnostic: diagnostic,
+		FixIndex:   fixIndex,
+		FixTitle:   action.Title,
+	}
+
+	if action.Edit == nil || action.Edit.Changes == nil || len(*action.Edit.Changes) == 0 {
+		return result
+	}
+
+	// Collect URIs in sorted order for deterministic output
+	uris := make([]lsproto.DocumentUri, 0, len(*action.Edit.Changes))
+	for uri := range *action.Edit.Changes {
+		uris = append(uris, uri)
+	}
+	slices.SortFunc(uris, func(a, b lsproto.DocumentUri) int {
+		return strings.Compare(string(a), string(b))
+	})
+
+	// Save original state and apply edits per file
+	type fileEditState struct {
+		uri             lsproto.DocumentUri
+		fileName        string
+		originalContent string
+		edits           []*lsproto.TextEdit
+	}
+	var editStates []fileEditState
+
+	for _, uri := range uris {
+		edits := (*action.Edit.Changes)[uri]
+		fileName := uri.FileName()
+		script := f.getScriptInfo(fileName)
+
+		beforeContent := ""
+		created := false
+		if script == nil {
+			created = true
+		} else {
+			beforeContent = script.content
+		}
+
+		// Save state for undo
+		editStates = append(editStates, fileEditState{
+			uri:             uri,
+			fileName:        fileName,
+			originalContent: beforeContent,
+			edits:           edits,
+		})
+
+		// Apply edits
+		savedActive := f.activeFilename
+		f.activeFilename = fileName
+
+		if script == nil {
+			// File doesn't exist yet - create it with empty content
+			script = newScriptInfo(fileName, "")
+			f.scriptInfos[fileName] = script
+		}
+
+		f.applyTextEdits(t, edits)
+		f.activeFilename = savedActive
+
+		afterContent := f.getScriptInfo(fileName).content
+
+		result.Changes = append(result.Changes, FileChange{
+			URI:     uri,
+			Before:  beforeContent,
+			After:   afterContent,
+			Created: created,
+		})
+	}
+
+	// Undo all changes in reverse order, notifying the LSP server
+	for i := len(editStates) - 1; i >= 0; i-- {
+		state := editStates[i]
+		script := f.getScriptInfo(state.fileName)
+		if state.originalContent == "" && script != nil {
+			// File was created - remove it
+			delete(f.scriptInfos, state.fileName)
+		} else if script != nil {
+			// Restore original content via editScript so the server is notified
+			f.editScript(t, state.fileName, core.TextChange{TextRange: core.NewTextRange(0, len(script.content)), NewText: state.originalContent})
+		}
+	}
+
+	return result
+}
