+// GetRefactorActionsForRange returns refactor actions available for the given selection range.
+// It sends a code action request with refactor.* kinds and returns matching actions.
+func (f *FourslashTest) GetRefactorActionsForRange(t *testing.T, fileURI lsproto.DocumentUri, selectionRange lsproto.Range) []RefactorActionInfo {
+	t.Helper()
+
+	params := &lsproto.CodeActionParams{
+		TextDocument: lsproto.TextDocumentIdentifier{
+			Uri: fileURI,
+		},
+		Range: selectionRange,
+		Context: &lsproto.CodeActionContext{
+			Only: &[]lsproto.CodeActionKind{lsproto.CodeActionKindRefactor},
+		},
+	}
+	codeActions := sendRequest(t, f, lsproto.TextDocumentCodeActionInfo, params)
+
+	var result []RefactorActionInfo
+	if codeActions.CommandOrCodeActionArray != nil {
+		for _, item := range *codeActions.CommandOrCodeActionArray {
+			if item.CodeAction != nil && item.CodeAction.Kind != nil && strings.HasPrefix(string(*item.CodeAction.Kind), "refactor.") {
+				result = append(result, RefactorActionInfo{
+					Title: item.CodeAction.Title,
+					Kind:  string(*item.CodeAction.Kind),
+				})
+			}
+		}
+	}
+	return result
+}
