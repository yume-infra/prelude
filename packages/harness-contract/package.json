{
  "name": "@sayoriqwq/prelude-contract",
  "type": "module",
  "version": "0.2.0",
  "description": "Effect Schema-backed contract for Prelude Harness Modules",
  "author": "sayoriqwq",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/yume-infra/prelude.git"
  },
  "keywords": [
    "effect",
    "harness",
    "prelude",
    "schema"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./conformance": {
      "types": "./dist/conformance.d.ts",
      "import": "./dist/conformance.js",
      "default": "./dist/conformance.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsdown --config tsdown.config.ts",
    "typecheck": "node --experimental-strip-types ../../tooling/run-tsgo.ts --noEmit --project tsconfig.json",
    "typecheck:tsc": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm build && vitest run",
    "lint": "eslint .",
    "verify": "pnpm build && pnpm typecheck && pnpm test && pnpm lint --max-warnings 0",
    "prepack": "pnpm build"
  },
  "peerDependencies": {
    "effect": "4.0.0-beta.97"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:",
    "@effect/platform-node": "catalog:",
    "@effect/tsgo": "catalog:",
    "@effect/vitest": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native": "catalog:",
    "effect": "catalog:",
    "eslint": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  }
}
