{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "tags": [
    "-lintignore"
  ],
  "ignoreDependencies": [
    "@effect/platform-node",
    "@typescript/native-preview",
    "effect",
    "@effect/vitest",
    "husky"
  ],
  "ignoreIssues": {
    "apps/cli/src/core/create/index.ts": [
      "types"
    ],
    "apps/cli/src/core/create/model.ts": [
      "types"
    ],
    "apps/cli/src/core/lifecycle/index.ts": [
      "types"
    ]
  },
  "workspaces": {
    ".": {
      "project": [
        "*.{js,mjs,cjs,ts}"
      ]
    },
    "apps/cli": {
      "entry": [
        "tests/**/*.ts"
      ],
      "project": [
        "*.config.ts",
        "src/**/*.ts",
        "tests/**/*.ts"
      ]
    }
  }
}
