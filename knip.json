{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "tags": [
    "-lintignore"
  ],
  "ignoreDependencies": [
    "@effect/platform-node",
    "@effect/tsgo",
    "@typescript/native-preview",
    "effect",
    "@effect/vitest",
    "husky"
  ],
  "workspaces": {
    ".": {
      "project": [
        "*.{js,mjs,cjs,ts}"
      ]
    },
    "apps/cli": {
      "entry": [
        "tests/**/*.ts"
      ],
      "project": [
        "*.config.ts",
        "src/**/*.ts",
        "tests/**/*.ts"
      ]
    },
    "packages/harness-contract": {
      "entry": [
        "src/index.ts",
        "src/conformance.ts",
        "tests/**/*.ts"
      ],
      "project": [
        "*.config.ts",
        "src/**/*.ts",
        "tests/**/*.ts"
      ]
    }
  }
}
